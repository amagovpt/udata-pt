# ==============================================================================
# udata — Environment Configuration (Example)
# All variables are consumed via udata.cfg through _env()/_env_bool()/_env_int().
# ==============================================================================


# ------------------------------------------------------------------------------
# Core
# ------------------------------------------------------------------------------

# Enables debug mode — exposes stack traces on HTTP 500.
DEBUG=True

SITE_ID=localhost:7000
SERVER_NAME=localhost:7000
PREFERRED_URL_SCHEME=http

# Base URL used for SAML redirects, CORS, and internal link generation.
CDATA_BASE_URL=http://localhost:3000


# ------------------------------------------------------------------------------
# Session
# ------------------------------------------------------------------------------

# Must be True in Production (requires HTTPS). Set False for local dev.
SESSION_COOKIE_SECURE=False


# ------------------------------------------------------------------------------
# Observability — Sentry
# ------------------------------------------------------------------------------

SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=dev


# ------------------------------------------------------------------------------
# Infrastructure — Service IPs
# ------------------------------------------------------------------------------

SERVER_MONGO=localhost
SERVER_REDIS=localhost

# SERVER_ELASTICSEARCH=127.0.0.1


# ------------------------------------------------------------------------------
# File Storage
# ------------------------------------------------------------------------------

# Filesystem root for uploaded resources.
# Local dev example: /home/user/workspace/new-dadosgov/udata-fs
FS_ROOT=/path/to/your/udata/fs/


# ------------------------------------------------------------------------------
# URL Validation
# ------------------------------------------------------------------------------

# URLS_ALLOW_LOCAL must be True in local dev if FS_URL is not configured.
URLS_ALLOW_LOCAL=True
URLS_ALLOW_PRIVATE=False

# Extra TLDs accepted during URL validation (comma-separated).
URLS_ADDITIONAL_TLDS=local,tst,dev


# ------------------------------------------------------------------------------
# Tabular Preview
# ------------------------------------------------------------------------------

# Internal URL of the tabular explore/preview service (udata backend itself).
TABULAR_EXPLORE_URL=http://localhost:7000


# ------------------------------------------------------------------------------
# Metrics API (api-tabular / Hydra)
# ------------------------------------------------------------------------------

METRICS_API=http://localhost:8006/api


# ------------------------------------------------------------------------------
# Resource Analyser (Hydra)
# ------------------------------------------------------------------------------

RESOURCES_ANALYSER_URI=http://localhost:8000
RESOURCES_ANALYSER_API_KEY=your_resource_analyser_api_key_here


# ------------------------------------------------------------------------------
# SAML Authentication (Autenticação.gov)
# ------------------------------------------------------------------------------

# Service Provider entity identifier.
SECURITY_SAML_ENTITY_ID=www.dados.gov.pt

# Human-readable SP display name shown on the IdP login page.
SECURITY_SAML_ENTITY_NAME=AMA - Dados Abertos (Dados Gov)

# Paths to SP key pair (relative to the application working directory).
SECURITY_SAML_KEY_FILE=udata/auth/saml/credentials/private.pem
SECURITY_SAML_CERT_FILE=udata/auth/saml/credentials/AMA.pem

# Path to IdP metadata XML.
SECURITY_SAML_IDP_METADATA=udata/auth/saml/credentials/metadata.xml

# Destination URL for SLO (Single Logout) requests.
SECURITY_SAML_FA_URL=https://preprod.autenticacao.gov.pt/fa/


# ------------------------------------------------------------------------------
# Password Policy (Flask-Security-Too)
# ------------------------------------------------------------------------------

SECURITY_PASSWORD_LENGTH_MIN=13
SECURITY_PASSWORD_REQUIREMENTS_LOWERCASE=True
SECURITY_PASSWORD_REQUIREMENTS_UPPERCASE=True
SECURITY_PASSWORD_REQUIREMENTS_DIGITS=True
SECURITY_PASSWORD_REQUIREMENTS_SYMBOLS=True


# ------------------------------------------------------------------------------
# E-mail (SMTP)
# ------------------------------------------------------------------------------

MAIL_SERVER=smtp.example.com
MAIL_PORT=25
MAIL_USE_TLS=False
MAIL_USE_SSL=False
MAIL_DEFAULT_SENDER=noreply@example.com
MAIL_DEFAULT_RECEIVER=admin@example.com


# ------------------------------------------------------------------------------
# Tags
# ------------------------------------------------------------------------------

TAG_MIN_LENGTH=0
TAG_MAX_LENGTH=250


# ------------------------------------------------------------------------------
# Export & Read-Only Mode
# ------------------------------------------------------------------------------

# MongoDB ObjectId of the dataset used for full CSV export generation.
EXPORT_CSV_DATASET_ID=your_dataset_object_id_here

# When True, disables all write operations (POST/PUT/DELETE) via the API.
READ_ONLY_MODE=False
